rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User data — each user reads/writes only their own document
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Experts — any authenticated user can read; writes are admin-only (Firebase Console)
    match /experts/{expertId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Bookings — user creates their own; both user and assigned expert can read/update
    match /bookings/{bookingId} {
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow read, update: if request.auth != null
                          && (resource.data.userId == request.auth.uid
                              || expertOwnsBooking(resource.data.expertId));
      allow delete: if false;
    }

    // Chat messages — only the booking's user and expert can read/write
    match /conversations/{bookingId}/messages/{msgId} {
      allow read, write: if request.auth != null
                         && bookingParticipant(bookingId);
    }

    // Helper: true when the logged-in user is the expert who owns this booking.
    // Matches by email because expert document IDs are not Firebase Auth UIDs.
    function expertOwnsBooking(expertDocId) {
      return exists(/databases/$(database)/documents/experts/$(expertDocId))
          && get(/databases/$(database)/documents/experts/$(expertDocId)).data.email
             == request.auth.token.email;
    }

    // Helper: true when the logged-in user is a participant of the booking.
    function bookingParticipant(bookingId) {
      let b = get(/databases/$(database)/documents/bookings/$(bookingId)).data;
      return b.userId == request.auth.uid
          || expertOwnsBooking(b.expertId);
    }
  }
}
